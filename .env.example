ENVIRONMENT=development
DEBUG=true
API_PREFIX=/api/v1

DATABASE_URL=postgresql://agentevalops:agentevalops@localhost:5432/agentevalops

REDIS_URL=redis://localhost:6379/0

QDRANT_URL=http://localhost:6333

DEFAULT_LLM_PROVIDER=mock
DEFAULT_LLM_MODEL=mock-llm

DEFAULT_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
DEFAULT_EMBEDDING_PROVIDER=sentence-transformers

OPENAI_API_KEY=
GROQ_API_KEY=

MAX_UPLOAD_MB=25
DEFAULT_RETRIEVAL_TOP_K=5
MAX_RETRIEVAL_TOP_K=20

ENABLE_TRACE_LOGGING=true
DEFAULT_INPUT_COST_PER_1K_TOKENS=0.0
DEFAULT_OUTPUT_COST_PER_1K_TOKENS=0.0

# llama-3.3-70b-versatile pricing: $0.59/M input, $0.79/M output
GROQ_INPUT_COST_PER_1K_TOKENS=0.00059
GROQ_OUTPUT_COST_PER_1K_TOKENS=0.00079

OPENAI_INPUT_COST_PER_1K_TOKENS=0.0
OPENAI_OUTPUT_COST_PER_1K_TOKENS=0.0

TOKEN_ESTIMATION_CHARS_PER_TOKEN=4
